@model html_to_pdf_aspose.Models.ConvertViewModel
@{
    ViewData["Title"] = "HTML to PDF Converter";
}

<div class="container py-4">
    <div class="row">
        <div class="col-lg-12">
            <h2 class="mb-3">HTML to PDF Converter</h2>
            <p class="text-muted">Convert HTML to PDF — no browser engine required.</p>

            @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @Model.ErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="Convert" method="post" enctype="multipart/form-data">
                <!-- Source Tabs -->
                <ul class="nav nav-tabs mb-3" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-html"
                                type="button" onclick="document.getElementById('ConversionSource').value='html'">
                            HTML Editor
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-file"
                                type="button" onclick="document.getElementById('ConversionSource').value='file'">
                            File Upload
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-url"
                                type="button" onclick="document.getElementById('ConversionSource').value='url'">
                            URL
                        </button>
                    </li>
                </ul>

                <input type="hidden" id="ConversionSource" name="ConversionSource" value="@Model?.ConversionSource" />

                <div class="tab-content">
                    <!-- HTML Editor Tab -->
                    <div class="tab-pane fade show active" id="tab-html">
                        <textarea name="HtmlContent" class="form-control font-monospace" rows="16"
                                  placeholder="Enter your HTML here...">@Model?.HtmlContent</textarea>
                    </div>

                    <!-- File Upload Tab -->
                    <div class="tab-pane fade" id="tab-file">
                        <div class="border rounded p-4 text-center bg-light">
                            <input type="file" name="HtmlFile" class="form-control" accept=".html,.htm,.xhtml" />
                            <small class="text-muted mt-2 d-block">Accepted formats: .html, .htm, .xhtml</small>
                        </div>
                    </div>

                    <!-- URL Tab -->
                    <div class="tab-pane fade" id="tab-url">
                        <input type="url" name="Url" class="form-control" value="@Model?.Url"
                               placeholder="https://example.com" />
                    </div>
                </div>

                <!-- PDF Settings -->
                <div class="card mt-3">
                    <div class="card-header">
                        <a class="text-decoration-none" data-bs-toggle="collapse" href="#pdfSettings">
                            PDF Settings
                        </a>
                    </div>
                    <div class="collapse show" id="pdfSettings">
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <label class="form-label">Page Size</label>
                                    <select name="PageSize" class="form-select">
                                        <option value="A4" selected="@(Model?.PageSize == html_to_pdf_aspose.Services.PageSize.A4)">A4</option>
                                        <option value="A3" selected="@(Model?.PageSize == html_to_pdf_aspose.Services.PageSize.A3)">A3</option>
                                        <option value="A5" selected="@(Model?.PageSize == html_to_pdf_aspose.Services.PageSize.A5)">A5</option>
                                        <option value="Letter" selected="@(Model?.PageSize == html_to_pdf_aspose.Services.PageSize.Letter)">Letter</option>
                                        <option value="Legal" selected="@(Model?.PageSize == html_to_pdf_aspose.Services.PageSize.Legal)">Legal</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Margin (mm)</label>
                                    <input type="number" name="MarginMm" class="form-control"
                                           value="@(Model?.MarginMm ?? 10)" min="0" max="100" />
                                </div>
                                <div class="col-md-3 d-flex align-items-end">
                                    <div class="form-check">
                                        <input type="checkbox" name="Landscape" value="true"
                                               class="form-check-input" id="chkLandscape"
                                               @(Model?.Landscape == true ? "checked" : "") />
                                        <label class="form-check-label" for="chkLandscape">Landscape</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary btn-lg">
                        Convert to PDF
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
